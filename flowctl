#!/bin/bash
# flowctl — start/stop/status for the whole Flow stack:
#   Ollama (LLM server) + Flow.app (hotkeys/typing) + watcher (transcription)
#
#   ./flowctl start     bring everything up now
#   ./flowctl stop      stop everything now (comes back at next login)
#   ./flowctl restart   stop + start
#   ./flowctl status    what's running
set -uo pipefail

UID_N=$(id -u)
APP_LABEL=com.connorsandford.flow.app
WATCHER_LABEL=com.connorsandford.flow.watcher
AGENTS_DIR="$HOME/Library/LaunchAgents"
APP="$HOME/Flow/app/Flow.app"

loaded() { launchctl print "gui/$UID_N/$1" &>/dev/null; }

do_start() {
    echo "Starting Flow…"
    # Ollama runs as a brew service; no-op if already up
    brew services start ollama >/dev/null 2>&1 || true

    for label in "$APP_LABEL" "$WATCHER_LABEL"; do
        if ! loaded "$label"; then
            launchctl bootstrap "gui/$UID_N" "$AGENTS_DIR/$label.plist" 2>/dev/null || true
        fi
    done
    # make sure the watcher process is actually up (KeepAlive restarts it too)
    launchctl kickstart "gui/$UID_N/$WATCHER_LABEL" 2>/dev/null || true
    open "$APP"
    sleep 2
    do_status
}

do_stop() {
    echo "Stopping Flow…"
    # bootout unloads the launchd jobs — required, otherwise KeepAlive
    # would resurrect the watcher seconds after a plain kill
    launchctl bootout "gui/$UID_N/$WATCHER_LABEL" 2>/dev/null || true
    launchctl bootout "gui/$UID_N/$APP_LABEL" 2>/dev/null || true
    pkill -f "flow.py watch" 2>/dev/null || true
    killall Flow 2>/dev/null || true
    sleep 1
    do_status
    echo "(Everything returns at next login; './flowctl start' brings it back sooner.)"
}

do_status() {
    printf "  %-10s" "Flow.app:";  pgrep -qf "Flow.app/Contents/MacOS/Flow" && echo "running" || echo "stopped"
    printf "  %-10s" "watcher:";   pgrep -qf "flow.py watch" && echo "running" || echo "stopped"
    printf "  %-10s" "ollama:";    pgrep -qx ollama && echo "running" || echo "stopped"
}

case "${1:-}" in
    start)   do_start ;;
    stop)    do_stop ;;
    restart) do_stop; echo; do_start ;;
    status)  do_status ;;
    *)       echo "usage: flowctl start|stop|restart|status"; exit 1 ;;
esac
